# --- RÈGLES GLOBALES ---
Host *
    ServerAliveInterval 60
    ServerAliveCountMax 3

# --- BASTION / VPN ---
Host vpn
    HostName xxx 
    User ubuntu
    IdentityFile ~/.ssh/id_ed25519_oracle

# --- MASTER K3S ---
Host master
    HostName xxx
    User ubuntu
    IdentityFile ~/.ssh/id_ed25519_oracle
    ProxyJump vpn

# --- WORKER K3S ---
Host worker
    HostName xxx
    User ubuntu
    IdentityFile ~/.ssh/id_ed25519_oracle
    ProxyJump vpn